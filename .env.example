# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Vector Store (FAISS) ─────────────────────────────────────────────────────
VECTOR_PERSIST_DIR=./vector_store

# ── LLM Models ────────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.jsonl

# ── Evaluation ────────────────────────────────────────────────────────────────
GROUND_TRUTH_PATH=./ground_truth/answers.json
